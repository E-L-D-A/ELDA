{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "jsPlugins": [
    "@elda/oxlint-plugin"
  ],
  "rules": {
    "elda/imports": "error",
    "elda/no-surface-declarations": "error",
    "elda/no-self-surface": "error",
    "elda/no-async-inner": "error",
    "elda/no-mutable-surface": "error",
    "elda/no-entity-state": "error",
    "elda/ambient-ownership": "error",
    "elda/no-service-coupling": "error",
    "elda/no-adapter-coupling": "error",
    "elda/no-penetration": "error",
    "elda/no-dishonest-placement": "error",
    "elda/no-deep-side-effects": "error",
    "elda/vocab-gate": "error",
    "elda/no-diagonal-reach": [
      "warn",
      {
        "acrossDomains": "error",
        "acrossSubdomains": "error",
        "withinSubdomain": "error"
      }
    ],
    "elda/no-diagonal-reach-gate": [
      "error",
      {
        "acrossDomains": "error",
        "acrossSubdomains": "error",
        "withinSubdomain": "error"
      }
    ]
  }
}
